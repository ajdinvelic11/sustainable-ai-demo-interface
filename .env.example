# App
APP_ENV=production
APP_PUBLIC_URL=http://localhost:30080
APP_JWT_SECRET=change-me
APP_JWT_ISSUER=sustainable-ai-demo-interface
APP_JWT_AUDIENCE=sustainable-ai-demo-users
APP_SESSION_TTL_MINUTES=120
APP_ADMIN_SUBJECTS=demo-admin
SESSION_COOKIE_NAME=sustainable_ai_session
CORS_ALLOWED_ORIGINS=http://localhost:30080
LOG_LEVEL=INFO

# Auth / VC-JWT validation
VC_JWT_VALIDATION_ENABLED=true
VC_JWT_VALIDATION_MOCK_MODE=false
VC_JWT_VALIDATION_URL=https://gxdch-nas-basic-functions.cloudcarib.com/api/jwt/compliance-verification
VC_JWT_VALIDATION_TIMEOUT_SECONDS=10
VC_JWT_VALIDATION_EXPECTED_COMPLIANT_FIELD=compliant

# PostgreSQL
DB_HOST=sustainable-ai-weather-db.c128kwgem8yu.eu-north-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=sustainable_ai_weather
DB_USER=postgres
DB_PASSWORD=change-me
DB_SSLMODE=require

# Demo
DEMO_MODEL_ID=sustainable-ai-model-v1
DEMO_MODEL_VERSION=v1.0
DEMO_TOTAL_DURATION_SECONDS=300
DEMO_ENFORCE_PHASE_TIMING=true
DEMO_COMMAND_POLL_INTERVAL_SECONDS=5
DEMO_STREAM_INTERVAL_SECONDS=2

# Sites
SITE_WIENER_NEUSTADT_LOCATION_NAME=Wiener Neustadt
SITE_WIENER_NEUSTADT_REGION_CODE=region_2
SITE_WIEN_LOCATION_NAME=Wien
SITE_WIEN_REGION_CODE=region_1
SITE_EISENSTADT_LOCATION_NAME=Eisenstadt
SITE_EISENSTADT_REGION_CODE=region_3

# S3
S3_BUCKET=weather-data-intelligent-ai-training

# Digital certificate export
CERTIFICATE_SIGNING_SECRET=change-me-to-a-long-random-secret
CERTIFICATE_ISSUER=Sustainable AI Demo Interface
